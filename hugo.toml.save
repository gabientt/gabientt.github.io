baseURL = "https://gabientt.github.io/"
languageCode = "pt-br"
title = "Enquanto Compila | Gabriely Vicente"
theme = "PaperMod"

[params]
  description = "Projetos e anotações de uma engenheira de computação"
  ShowReadingTime = true
  ShowShareButtons = false
  ShowPostNavLinks = true
  ShowBreadCrumbs = true
  ShowCodeCopyButtons = true
  defaultTheme = "dark"
  customCSS = ["css/custom.css"]

[params.homeInfoParams]
  Title = "Enquanto Compila"
  Content = """
Olá! Eu sou Gabriely Vicente, estudante do último ano de Engenharia de Computação no Instituto Federal Fluminense e esse é o Enquanto Compila.

Um espaço que nasceu de uma vontade de documentar projetos e problemas reais e o raciocínio por trás de cada uma das soluções da forma menos complicada possível.

Enquanto Compila é aquela sensação de bater um papo no cafezinho da tarde, com bolinho quente e conversa boa. Entender um código é importante mas não precisa ser complicado.
"""[params.homeInfoParams]
  Title = "Enquanto Compila "
  Content = "Olá! Eu sou Gabriely Vicente, estudante do último ano de Engenharia de Computação no Instituto Federal Fluminense e esse é o Enquanto Compila. Um espaço que nasceu de uma vontade de documentar projetos e problemas reais e o raciocínio por trás de cada uma das soluções da forma menos complicada possível.\n\nEnquanto Compila é aquela sensação de bater um papo no cafezinho da tarde com bolinho quente e conversa boa. Entender um código é importante mas não precisa ser complicado."

[[params.socialIcons]]
  name = "github"
  url = "https://github.com/gabientt"

[[params.socialIcons]]
  name = "linkedin"
  url = "https://www.linkedin.com/in/gabriely-vicente-7b6931272"

[[params.socialIcons]]
  name = "email"
  url = "mailto:gabient.ut@gmail.com"

[markup.highlight]
  style = "dracula"
  lineNos = true
